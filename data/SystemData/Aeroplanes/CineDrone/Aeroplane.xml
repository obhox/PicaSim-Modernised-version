<!--
  Cine Drone - heavy, ultra-smooth camera/GPS-style drone. Full-size Wasp mesh,
  heavy payload and slow, gentle stabilisation for smooth cinematic moves. Always
  self-levelling with altitude hold - point it and it drifts smoothly, holding height.
-->

<Misc launchOffsetX="2.0" launchOffsetY="0.0" launchOffsetZ="0.2" launchSpeed="0.0" />
