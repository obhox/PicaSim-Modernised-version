<!--
  Tiny Whoop - tiny indoor/micro quad. Wasp geometry and mesh scaled to half size
  (modelScale 0.5, all positions halved so the reused props stay aligned). Light,
  self-levelling and altitude-holding for easy indoor-style flying in a small space.
-->

<Misc
  launchOffsetX="1.0"
  launchOffsetY="0.0"
  launchOffsetZ="0.1"
  launchSpeed="0.0"
/>
<Physics>
  <Dynamics friction="1.0" frictionScaleX="1" frictionScaleY="1" frictionScaleZ="1" />

  <Aerodynamics>
    <!-- X forward, Y left, Z up. Positions = Wasp x0.5 -->
    <PropellerEngine
      name="FL"
      positionX="0.0795"
      positionY="0.0795"
      positionZ="0.02"
      rotationY="-90.0"
      numBlades="2"
      numRings="4"
      radius="0.0635"
      pitch="0.057"
      bladeChord="0.005"
      CL0="0.5"
      CLPerDegree="0.1"
      CD0="0.1"
      CDInducedMultiplier="2.0"
      stallAngle="15"
      inertia="0.00002"
      maxTorque="0.25"
      maxRPM="-15000"
      minRPM="0"
      frictionTorque="0.05"
      transitionalLiftAmount="0.06"
      transitionalLiftSpeed="2.0"
      controlExp="0.5"
      controlRate="60"
      gyroName0="Pitch" controlPerGyro0="1"
      gyroName1="Roll"  controlPerGyro1="-1"
      gyroName2="Yaw"   controlPerGyro2="-1"
      gyroName3="Throttle" controlPerGyro3="1"
      audioFile="SystemData/Audio/Motor22050Mono.raw"
      audioSampleRate="22050"
      audioRadius="0.15"
      audioMinVolume="0"
      audioMaxVolume="0.7"
      audioMinFreqScale="0.4"
      audioMaxFreqScale="2.5"
      colourX="0.0" colourY="1.0" colourZ="0.0" colourW="0.1"
    />
    <PropellerEngine name="FR" copy="FL" positionY="-0.0795" maxRPM="15000" controlPerGyro1="1" controlPerGyro2="1" />
    <PropellerEngine name="BL" copy="FL" positionX="-0.0795" maxRPM="15000" controlPerGyro0="-1" controlPerGyro2="1" colourX="1.0" colourY="0.0" />
    <PropellerEngine name="BR" copy="FL" positionX="-0.0795" positionY="-0.0795" controlPerGyro0="-1" controlPerGyro1="1" colourX="1.0" colourY="0.0" />

    <Fuselage name="Payload" mass="0.03" positionX="0.0" positionY="0.0" positionZ="0.005"
      extentsX="0.05" extentsY="0.05" extentsZ="0.04" CDX="1" CDY="1" CDZ="1" render="false" />
    <Fuselage name="Frame1" mass="0.01" positionX="0.0" positionY="0.0" positionZ="0.0" yaw="45"
      extentsX="0.25" extentsY="0.025" extentsZ="0.005" CDX="1" CDY="1" CDZ="1" render="false" />
    <Fuselage name="Frame2" mass="0.01" positionX="0.0" positionY="0.0" positionZ="0.0" yaw="-45"
      extentsX="0.25" extentsY="0.025" extentsZ="0.005" CDX="1" CDY="1" CDZ="1" render="false" />

    <Wing name="FwdBack" aerofoil="SystemData/Aerofoils/Symmetric/NACA0009" numSections="1" mass="0.0"
      positionX="0.0" positionY="-0.025" positionZ="0.0" extentsX="0.05" extentsY="0.05" extentsZ="0.005" wingAspectRatio="1.0" render="true" />
    <Wing name="BackFwd" aerofoil="SystemData/Aerofoils/Symmetric/NACA0009" numSections="1" mass="0.0"
      positionX="0.0" positionY="0.025" positionZ="0.0" extentsX="0.05" extentsY="0.05" extentsZ="0.005" yaw="180" wingAspectRatio="1.0" render="true" />
    <Wing name="LeftRight" aerofoil="SystemData/Aerofoils/Symmetric/NACA0009" numSections="1" mass="0.0"
      positionX="0.025" positionY="0.0" positionZ="0.0" yaw="90" extentsX="0.05" extentsY="0.05" extentsZ="0.005" wingAspectRatio="1.0" render="true" />
    <Wing name="RightLeft" aerofoil="SystemData/Aerofoils/Symmetric/NACA0009" numSections="1" mass="0.0"
      positionX="-0.025" positionY="0.0" positionZ="0.0" yaw="-90" extentsX="0.05" extentsY="0.05" extentsZ="0.005" wingAspectRatio="1.0" render="true" />
  </Aerodynamics>

  <Gyros>
    <Gyro name="Yaw" axisX="0" axisY="0" axisZ="1" gain="0.05" initialMode="axis" rotationRatePerChannel2="10" />
    <Gyro name="Throttle" type="height" axisX="0" axisY="0" axisZ="0" gain="1.0" initialMode="stabilisedHeight"
      passThroughPerChannel3="1" heightRatePerChannel3="4" />
    <Gyro name="Roll" axisX="1" axisY="0" axisZ="0" gain="0.3" channelForMode="6"
      anglePerChannel0="25" rotationRatePerChannel0="-6" speedPerChannel0="6" tiltPerSpeed="10" maxTilt="30" />
    <Gyro name="Pitch" axisX="0" axisY="1" axisZ="0" gain="0.3" channelForMode="6"
      anglePerChannel1="25" rotationRatePerChannel1="-6" speedPerChannel1="6" tiltPerSpeed="10" maxTilt="30" />
  </Gyros>

  <Geometry>
    <Shape type="box" name="FL" mass="0.008" positionX="0.0795" positionY="0.0795" positionZ="0.01"
      extentsX="0.01" extentsY="0.01" extentsZ="0.02"
      colourTopX="0" colourTopY="1" colourTopZ="0" colourSidesX="0" colourSidesY="1" colourSidesZ="0" colourBottomX="0" colourBottomY="1" colourBottomZ="0" render="true" />
    <Shape type="box" name="FR" mass="0.008" positionX="0.0795" positionY="-0.0795" positionZ="0.01"
      extentsX="0.01" extentsY="0.01" extentsZ="0.02"
      colourTopX="0" colourTopY="1" colourTopZ="0" colourSidesX="0" colourSidesY="1" colourSidesZ="0" colourBottomX="0" colourBottomY="1" colourBottomZ="0" render="true" />
    <Shape type="box" name="BL" mass="0.008" positionX="-0.0795" positionY="0.0795" positionZ="0.01"
      extentsX="0.01" extentsY="0.01" extentsZ="0.02"
      colourTopX="1" colourTopY="0" colourTopZ="0" colourSidesX="1" colourSidesY="0" colourSidesZ="0" colourBottomX="1" colourBottomY="0" colourBottomZ="0" render="true" />
    <Shape type="box" name="BR" mass="0.008" positionX="-0.0795" positionY="-0.0795" positionZ="0.01"
      extentsX="0.01" extentsY="0.01" extentsZ="0.02"
      colourTopX="1" colourTopY="0" colourTopZ="0" colourSidesX="1" colourSidesY="0" colourSidesZ="0" colourBottomX="1" colourBottomY="0" colourBottomZ="0" render="true" />
  </Geometry>

  <CrashShapes>
    <CrashShape type="box" name="Props" engineName="FL" crashPropSpeed="30"
      positionX="0.0" positionY="0.0" positionZ="0.03" rotationX="0"
      extentsX="0.3" extentsY="0.3" extentsZ="0.025" render="false" />
  </CrashShapes>

</Physics>

<Graphics>
  <Model
    name="Standard"
    model3DS="SystemData/Aeroplanes/Wasp/Wasp.ac"
    modelScale="0.5"
    cullBackFace="true"
    unsetColourR="255" unsetColourG="255" unsetColourB="0"
    offsetX="0" offsetY="0.0" offsetZ="0.0"
    />
  <ControlSurface name="PropellerFL" source="FL"
    hingePoint1X="-0.155563" hingePoint1Y="1" hingePoint1Z="-0.155564"
    hingePoint2X="-0.155563" hingePoint2Y="0" hingePoint2Z="-0.155564" />
  <ControlSurface name="PropellerFR" source="FR"
    hingePoint1X="0.155563" hingePoint1Y="0" hingePoint1Z="-0.155564"
    hingePoint2X="0.155563" hingePoint2Y="1" hingePoint2Z="-0.155564" />
  <ControlSurface name="PropellerBL" source="BL"
    hingePoint1X="-0.155563" hingePoint1Y="0" hingePoint1Z="0.155564"
    hingePoint2X="-0.155563" hingePoint2Y="1" hingePoint2Z="0.155564" />
  <ControlSurface name="PropellerBR" source="BR"
    hingePoint1X="0.155563" hingePoint1Y="1" hingePoint1Z="0.155564"
    hingePoint2X="0.155563" hingePoint2Y="0" hingePoint2Z="0.155564" />
</Graphics>
